
# --- Server Settings ---
SC_APP_NODE_ENV=development|production
SC_APP_PORT=<port_number>
SC_APP_HOST=<host_address>

# --- Database & Security ---
SC_APP_DATABASE_URL=db
SC_APP_CORS_ORIGINS=url
SESSION_TIMEOUT=milliseconds
ENFORCE_HTTPS=boolean
HELMET_ENABLED=boolean

# --- Groq AI Configuration ---
# Get keys at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

GROQ_MODEL=model_name
GROQ_TEMPERATURE=0.0-1.0

# --- Google AI Configuration ---
GOOGLE_GENERATIVE_AI_API_KEY=

# --- AI Feature Flags ---
AI_FEATURES_ENABLED=boolean
STREAMING_ENABLED=boolean
COMPARISON_ENABLED=boolean

# --- Rate Limiting & Session Management ---
MAX_MESSAGES_PER_SESSION=number
RATE_LIMIT_WINDOW_MINUTES=number
RATE_LIMIT_MAX_REQUESTS=number

# --- Logging & Monitoring ---
LOG_LEVEL=debug|info|warn|error
LOG_FORMAT=json
DEBUG_MODE=false
METRICS_ENABLED=true